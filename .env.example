# =============================================================================
# Get Mumm — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# =============================================================================

# --- Database ---
# Full PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/getmumm

# --- Auth ---
# JWT signing secret — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-use-a-long-random-string-in-production

# --- Paymob (optional — card payments) ---
# Get from: https://accept.paymob.com → Settings → API Key
PAYMOB_API_KEY=

# Get from: Paymob dashboard → Developers → Payment Integrations → Card integration ID
PAYMOB_INTEGRATION_ID=

# Get from: Paymob dashboard → Developers → Iframes → iframe ID
PAYMOB_IFRAME_ID=

# --- Ports (optional — defaults shown) ---
PORT=8080            # API server port
# PORT=5000          # Frontend dev server port (set in Get Mumm App workflow)
